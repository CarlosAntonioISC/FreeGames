<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FreeGames" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
    
    <style name="TextMinimumSystemRequirements">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/fg_16text</item>
    </style>

    <style name="TextGenre">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/background_btn_genre</item>
        <item name="android:paddingStart">@dimen/fg_10dp</item>
        <item name="android:paddingEnd">@dimen/fg_10dp</item>
        <item name="android:paddingTop">@dimen/fg_10dp</item>
        <item name="android:paddingBottom">@dimen/fg_10dp</item>
        <item name="android:textColor">@color/blackCard</item>
        <item name="android:textSize">@dimen/fg_12text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextFree">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/background_btn_free</item>
        <item name="android:paddingStart">@dimen/fg_10dp</item>
        <item name="android:paddingEnd">@dimen/fg_10dp</item>
        <item name="android:paddingTop">@dimen/fg_10dp</item>
        <item name="android:paddingBottom">@dimen/fg_10dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/fg_12text</item>
        <item name="android:textStyle">bold</item>
    </style>


</resources>